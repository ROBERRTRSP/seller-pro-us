{
  "name": "tienda-ventas",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "rm -rf .next node_modules/.cache .turbo",
    "dev": "prisma generate && next dev --turbopack",
    "dev:3456": "prisma generate && next dev --turbopack -p 3456",
    "dev:clean": "npm run clean && prisma generate && next dev --turbopack",
    "dev:webpack": "prisma generate && next dev",
    "build": "prisma generate && next build",
    "build:with-migrate": "prisma generate && prisma migrate deploy && next build",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "db:clear": "npx tsx prisma/clear-store.ts",
    "db:import:april-special": "npx tsx prisma/import-april-special.ts",
    "db:apply:verified-images": "npx tsx prisma/apply-verified-catalog-images.ts",
    "db:catalogo:april": "npm run db:import:april-special && npm run db:apply:verified-images",
    "db:import:jr-black-mild": "npx tsx prisma/import-jr-black-mild-catalog.ts",
    "db:sync:catalog": "prisma db seed",
    "db:studio": "prisma studio",
    "catalogo:lavaplus": "npx tsx scripts/scrape-lavaplus-shop.ts",
    "db:import:lavaplus": "npx tsx prisma/import-lavaplus-5999.ts",
    "db:import:jr-backwoods": "npx tsx prisma/import-jr-backwoods-draft.ts",
    "db:import:jr-dutch-masters": "npx tsx prisma/import-dutch-masters-jr.ts",
    "db:publish:all-catalog": "npx tsx prisma/publish-all-catalog.ts",
    "db:import:bluntville-our-story": "npx tsx prisma/import-bluntville-our-story.ts",
    "db:import:flash-backwoods": "npx tsx prisma/import-flash-backwoods-offers.ts",
    "catalog:blunt-backwoods": "npx tsx scripts/build-catalogo-blunt-backwoods.ts",
    "db:import:bulk-catalog": "npx tsx prisma/bulk-import-catalog.ts"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@vercel/blob": "^0.27.3",
    "bcryptjs": "^3.0.3",
    "heic-convert": "^2.1.0",
    "jose": "^6.2.2",
    "next": "15.5.15",
    "qrcode": "^1.5.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.19.39",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "15.5.15",
    "postcss": "^8.5.9",
    "prisma": "^6.19.3",
    "tailwindcss": "^3.4.19",
    "sharp": "^0.34.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
