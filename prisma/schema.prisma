generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CLIENT
  ADMIN
}

/** Una sola fila (`id = "default"`): textos de la tienda y metadatos editables por el administrador. */
model SiteSettings {
  id                 String   @id @default("default")
  siteTitle          String   @default("")
  siteDescription    String   @default("")
  storeName          String   @default("")
  storefrontNotice   String   @default("")
  navBrowse          String   @default("")
  navCart            String   @default("")
  navOrders          String   @default("")
  heroEyebrow        String   @default("")
  heroTitle          String   @default("")
  heroSubtitle       String   @default("")
  heroBody           String   @default("")
  heroCtaLabel       String   @default("")
  updatedAt          DateTime @updatedAt
}

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  password        String
  name            String
  role            Role     @default(CLIENT)
  phone           String?
  /** Dirección postal / de entrega del cliente (obligatoria para rol CLIENT). */
  address         String?
  businessLicense String?
  tobaccoLicense  String?
  createdAt       DateTime @default(now())
  orders          Order[]
}

model Category {
  id        String    @id @default(cuid())
  name      String    @unique
  sortOrder Int       @default(0)
  createdAt DateTime  @default(now())
  products  Product[]
}

model Product {
  id                   String      @id @default(cuid())
  name                 String
  description          String
  /** Internal / import code (AAA Wholesale, etc.). */
  sku                  String?     @unique
  /** EAN-12 / UPC style code for scanning. */
  barcode              String?     @unique
  priceCents           Int
  /** Strikethrough “Was” price in catalog; must be greater than priceCents when set. */
  compareAtPriceCents  Int?
  /** Promo label e.g. Rollback, Clearance, Reduced price. */
  promoBadge           String?
  categoryId           String?
  category             Category?   @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  /** Units available to sell (0 = out of stock). Reserved atomically when an order is placed or edited; restored on cancel. */
  stock                Int         @default(25)
  /** When true, la tienda muestra «foto pendiente» y no usa imageUrl aunque exista borrador en historial (siempre null en flujo nuevo). */
  imagePending         Boolean     @default(false)
  imageUrl             String?
  createdAt            DateTime      @default(now())
  orderItems           OrderItem[]
}

model Order {
  id         String      @id @default(cuid())
  userId     String
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  status     String      @default("PENDIENTE")
  totalCents Int
  adminNote  String?
  /** When the store accepts the order; the shopper can no longer edit or cancel. */
  acceptedAt DateTime?
  createdAt  DateTime    @default(now())
  items      OrderItem[]
}

model OrderItem {
  id         String  @id @default(cuid())
  orderId    String
  order      Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId  String
  product    Product @relation(fields: [productId], references: [id])
  quantity   Int
  priceCents Int
}
